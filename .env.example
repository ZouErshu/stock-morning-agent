# ========== LLM 配置 ==========
# DeepSeek API（推荐，国内直连，价格极低）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 也可以用其他兼容 OpenAI 格式的 API（如智谱、通义、Moonshot）
# 只需改 base_url 和 model 即可
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3

# ========== 飞书机器人配置 ==========
# 申请地址：https://open.feishu.cn/app
# 1. 创建企业自建应用
# 2. 添加「机器人」能力
# 3. 开启「事件订阅」-> 选择「长连接模式」（无需公网IP）
# 4. 订阅事件：im.message.receive_v1（接收消息）
# 5. 权限管理 -> 开启：im:message, im:message:send_as_bot
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== 推送配置 ==========
# 早报定时推送时间（24小时制，本地时间）
PUSH_HOUR=7
PUSH_MINUTE=30

# 推送目标：单聊填用户 open_id，群聊填群 chat_id
# 获取方式：先把机器人加到群/单聊，发一条消息触发，日志会打印出 chat_id
FEISHU_RECEIVE_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxx
# receive_id_type: chat 表示群聊，open_id 表示单聊
FEISHU_RECEIVE_ID_TYPE=chat

# ========== 日志配置 ==========
LOG_LEVEL=INFO
